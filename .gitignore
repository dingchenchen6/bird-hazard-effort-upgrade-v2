# ---- Large / regenerable data ----
# 任何 data/ 下的 derived 数据都视为可重生成；只保留 schema 和文档
data/raw/
data/spatial/
data/derived/*.parquet
data/derived/*.fst
data/derived/*.csv
data/derived/*.rds
data/derived/*.gpkg
data/derived/*.tif
*.rds
*.RData

# ---- Any CSV / parquet > 1 MB anywhere under data/ except dictionaries ----
# (additional safety net; specific patterns above already cover the common cases)

# ---- Local R session debris ----
.Rhistory
.RData
.Ruserdata
.Rapp.history

# ---- renv (only the lockfile + activate stub are tracked) ----
renv/library/
renv/python/
renv/staging/
renv/local/

# ---- targets pipeline cache ----
targets/
_targets/

# ---- Logs and self-check artefacts ----
logs/
*.log

# ---- Large figures (regenerated by 34/35) ----
figures/main/*.pdf
figures/main/*.png
figures/supplementary/*.pdf
figures/supplementary/*.png
figures/diagnostics/*.pdf
figures/diagnostics/*.png

# Keep small diagnostic + readme figures
!figures/README.md

# ---- v1 reference symlinks ----
code/v1_reference/

# ---- macOS / IDE clutter ----
.DS_Store
.Rproj.user/
.vscode/
.idea/
.workbuddy/
.codebuddy/
.claude/

# ---- Outputs of multiscale run (regenerable) ----
outputs_multiscale/data/
outputs_multiscale/results/
outputs_multiscale/figures/
outputs_multiscale/logs/

# ---- Manuscript build artefacts ----
manuscript/manuscript_v2.md
manuscript/manuscript_v2.docx
manuscript/manuscript_v2.pdf
manuscript/manuscript_v2.tex
manuscript/manuscript_v2_files/
manuscript/_main_cache/

# ---- Editor backups ----
*~
*.bak
*.swp

# ---- Deployment-only scripts that include credentials or paths ----
# (none expected; deploy/ is tracked for documentation reference)

# ---- Session-info snapshots that change every run ----
sessionInfo.txt
